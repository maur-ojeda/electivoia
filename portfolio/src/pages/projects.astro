---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProjectCard from '../components/ProjectCard.astro';

const projects = [
  {
    title: 'ElectivoIA',
    description: 'Educational management platform with AI-powered course recommendations. Manages students, teachers, courses, enrollments, and attendance tracking.',
    tags: ['PHP', 'Symfony 7', 'Doctrine ORM', 'MySQL', 'JavaScript', 'Bootstrap 5'],
    link: '/projects/electivoia',
    github: 'https://github.com/maur-ojeda/electivoia',
  },
  // Agrega más proyectos aquí cuando los tengas
];
---

<Layout title="Projects - Mauricio Ojeda" description="Explore my portfolio of web development projects">
  <Header />
  
  <main>
    <section class="page-header">
      <div class="container">
        <h1 class="page-title">Projects</h1>
        <p class="page-subtitle">
          A collection of projects I've built, showcasing my skills in full-stack development
        </p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="projects-grid">
          {projects.map((project) => (
            <ProjectCard {...project} />
          ))}
        </div>
        
        {projects.length === 0 && (
          <div class="empty-state">
            <p>More projects coming soon...</p>
          </div>
        )}
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>

<style>
  .page-header {
    padding: var(--spacing-3xl) 0 var(--spacing-xl);
    text-align: center;
  }
  
  .page-title {
    margin-bottom: var(--spacing-md);
  }
  
  .page-subtitle {
    font-size: 1.25rem;
    max-width: 600px;
    margin: 0 auto;
  }
  
  .section {
    padding: var(--spacing-2xl) 0 var(--spacing-3xl);
  }
  
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: var(--spacing-xl);
  }
  
  @media (max-width: 768px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
  
  .empty-state {
    text-align: center;
    padding: var(--spacing-3xl) 0;
    color: var(--color-text-muted);
  }
</style>
