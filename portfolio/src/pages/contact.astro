---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact - Mauricio Ojeda" description="Get in touch with Mauricio Ojeda">
  <Header />
  
  <main>
    <section class="page-header">
      <div class="container">
        <h1 class="page-title">Get in Touch</h1>
        <p class="page-subtitle">
          I'm always open to discussing new projects, opportunities, or just having a chat about technology
        </p>
      </div>
    </section>

    <section class="section">
      <div class="container content-container">
        <div class="contact-grid">
          <div class="contact-info">
            <h2>Let's Connect</h2>
            <p>
              Whether you have a project in mind, want to collaborate, or just want to say hi, 
              feel free to reach out. I'll do my best to get back to you as soon as possible.
            </p>
            
            <div class="contact-methods">
              <a href="mailto:mauricio@example.com" class="contact-method">
                <div class="method-icon">📧</div>
                <div class="method-content">
                  <h3>Email</h3>
                  <p>mauricio@example.com</p>
                </div>
              </a>
              
              <a href="https://github.com/maur-ojeda" class="contact-method" target="_blank" rel="noopener noreferrer">
                <div class="method-icon">💻</div>
                <div class="method-content">
                  <h3>GitHub</h3>
                  <p>@maur-ojeda</p>
                </div>
              </a>
              
              <a href="https://linkedin.com/in/mauricio-ojeda" class="contact-method" target="_blank" rel="noopener noreferrer">
                <div class="method-icon">💼</div>
                <div class="method-content">
                  <h3>LinkedIn</h3>
                  <p>Mauricio Ojeda</p>
                </div>
              </a>
            </div>
            
            <div class="availability">
              <h3>Current Availability</h3>
              <p>
                I'm currently <span class="status-badge">available</span> for freelance projects 
                and open to discussing full-time opportunities.
              </p>
            </div>
          </div>
          
          <div class="contact-form-container">
            <form class="contact-form" action="https://formspree.io/f/YOUR_FORM_ID" method="POST">
              <div class="form-group">
                <label for="name">Name</label>
                <input 
                  type="text" 
                  id="name" 
                  name="name" 
                  required 
                  placeholder="Your name"
                />
              </div>
              
              <div class="form-group">
                <label for="email">Email</label>
                <input 
                  type="email" 
                  id="email" 
                  name="email" 
                  required 
                  placeholder="your.email@example.com"
                />
              </div>
              
              <div class="form-group">
                <label for="subject">Subject</label>
                <input 
                  type="text" 
                  id="subject" 
                  name="subject" 
                  required 
                  placeholder="What's this about?"
                />
              </div>
              
              <div class="form-group">
                <label for="message">Message</label>
                <textarea 
                  id="message" 
                  name="message" 
                  rows="6" 
                  required 
                  placeholder="Tell me about your project or inquiry..."
                ></textarea>
              </div>
              
              <button type="submit" class="btn btn-primary">
                Send Message
              </button>
            </form>
            
            <p class="form-note">
              Note: Replace the form action URL with your own Formspree endpoint or preferred form service
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>

<style>
  .page-header {
    padding: var(--spacing-3xl) 0 var(--spacing-xl);
    text-align: center;
  }
  
  .page-title {
    margin-bottom: var(--spacing-md);
  }
  
  .page-subtitle {
    font-size: 1.25rem;
    max-width: 600px;
    margin: 0 auto;
  }
  
  .section {
    padding: var(--spacing-2xl) 0 var(--spacing-3xl);
  }
  
  .content-container {
    max-width: 1000px;
  }
  
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-3xl);
  }
  
  .contact-info h2 {
    font-size: 2rem;
    margin-bottom: var(--spacing-md);
    color: var(--color-text);
  }
  
  .contact-info > p {
    margin-bottom: var(--spacing-xl);
    line-height: 1.8;
  }
  
  .contact-methods {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-xl);
  }
  
  .contact-method {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    padding: var(--spacing-md);
    background: var(--color-card-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: all 0.2s ease;
  }
  
  .contact-method:hover {
    border-color: var(--color-accent);
    transform: translateX(4px);
  }
  
  .method-icon {
    font-size: 2rem;
  }
  
  .method-content h3 {
    font-size: 1rem;
    margin-bottom: 0.25rem;
    color: var(--color-text);
  }
  
  .method-content p {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin: 0;
  }
  
  .availability {
    padding: var(--spacing-lg);
    background: var(--color-card-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }
  
  .availability h3 {
    font-size: 1.125rem;
    margin-bottom: var(--spacing-sm);
    color: var(--color-text);
  }
  
  .availability p {
    margin: 0;
    line-height: 1.7;
  }
  
  .status-badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    background: #10b981;
    color: white;
    border-radius: var(--radius-sm);
    font-size: 0.875rem;
    font-weight: 500;
  }
  
  .contact-form-container {
    background: var(--color-card-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--spacing-xl);
  }
  
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }
  
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  
  .form-group label {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-text);
  }
  
  .form-group input,
  .form-group textarea {
    padding: 0.75rem;
    font-size: 1rem;
    font-family: var(--font-sans);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-text);
    transition: border-color 0.2s ease;
  }
  
  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-accent);
  }
  
  .form-group textarea {
    resize: vertical;
    min-height: 120px;
  }
  
  .btn {
    display: inline-block;
    padding: 0.875rem 1.75rem;
    font-size: 1rem;
    font-weight: 500;
    border-radius: var(--radius-md);
    transition: all 0.2s ease;
    text-decoration: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-sans);
  }
  
  .btn-primary {
    background: var(--color-accent);
    color: white;
  }
  
  .btn-primary:hover {
    background: var(--color-accent-hover);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }
  
  .form-note {
    margin-top: var(--spacing-md);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    font-style: italic;
  }
  
  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-xl);
    }
  }
</style>
