<!DOCTYPE html>
<html lang="es" data-theme="light">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>{% block title %}ElectivoIA{% endblock %}</title>
	{% block stylesheets %}
		{{ encore_entry_link_tags('app') }}
	{% endblock %}
</head>
<body class="min-h-screen bg-base-200">

	{# Navbar role-aware #}
	<div class="navbar bg-base-100 shadow-sm px-4 sticky top-0 z-50">
		<div class="navbar-start">
			{% if app.user %}
				<div class="dropdown">
					<label tabindex="0" class="btn btn-ghost lg:hidden">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h8m-8 6h16"/>
						</svg>
					</label>
					<ul tabindex="0" class="menu menu-sm dropdown-content mt-3 z-[1] p-2 shadow bg-base-100 rounded-box w-52">
						{% if is_granted('ROLE_STUDENT') %}
							<li><a href="{{ path('student_dashboard') }}">Dashboard</a></li>
							<li><a href="{{ path('student_courses') }}">Cursos</a></li>
							<li><a href="{{ path('student_enrollments') }}">Mis Cursos</a></li>
							<li><a href="{{ path('student_attendance') }}">Asistencia</a></li>
						{% elseif is_granted('ROLE_TEACHER') %}
							<li><a href="{{ path('teacher_courses') }}">Mis Cursos</a></li>
						{% elseif is_granted('ROLE_GUARDIAN') %}
							<li><a href="{{ path('guardian_dashboard') }}">Dashboard</a></li>
						{% elseif is_granted('ROLE_SUPER_ADMIN') %}
							<li><a href="{{ path('super_admin_dashboard') }}">Super Admin</a></li>
							<li><a href="{{ path('super_admin_onboard') }}">+ Colegio</a></li>
							<li><a href="{{ path('admin') }}">EasyAdmin</a></li>
						{% elseif is_granted('ROLE_ADMIN') %}
							<li><a href="{{ path('admin') }}">Panel Admin</a></li>
							<li><a href="{{ path('admin_reports_index') }}">Reportes</a></li>
							<li><a href="{{ path('admin_enrollment_period') }}">Inscripciones</a></li>
						{% endif %}
					</ul>
				</div>
			{% endif %}
			<a href="/" class="btn btn-ghost text-xl font-bold text-primary">ElectivoIA</a>
		</div>

		<div class="navbar-center hidden lg:flex">
			{% if app.user %}
				<ul class="menu menu-horizontal px-1 gap-1">
					{% if is_granted('ROLE_STUDENT') %}
						<li><a href="{{ path('student_dashboard') }}" class="rounded-btn">Dashboard</a></li>
						<li><a href="{{ path('student_courses') }}" class="rounded-btn">Cursos</a></li>
						<li><a href="{{ path('student_enrollments') }}" class="rounded-btn">Mis Cursos</a></li>
						<li><a href="{{ path('student_attendance') }}" class="rounded-btn">Asistencia</a></li>
					{% elseif is_granted('ROLE_TEACHER') %}
						<li><a href="{{ path('teacher_courses') }}" class="rounded-btn">Mis Cursos</a></li>
					{% elseif is_granted('ROLE_GUARDIAN') %}
						<li><a href="{{ path('guardian_dashboard') }}" class="rounded-btn">Dashboard</a></li>
					{% elseif is_granted('ROLE_SUPER_ADMIN') %}
						<li><a href="{{ path('super_admin_dashboard') }}" class="rounded-btn">Super Admin</a></li>
						<li><a href="{{ path('super_admin_onboard') }}" class="rounded-btn">+ Colegio</a></li>
						<li><a href="{{ path('admin') }}" class="rounded-btn">EasyAdmin</a></li>
					{% elseif is_granted('ROLE_ADMIN') %}
						<li><a href="{{ path('admin') }}" class="rounded-btn">Panel Admin</a></li>
						<li><a href="{{ path('admin_reports_index') }}" class="rounded-btn">Reportes</a></li>
						<li><a href="{{ path('admin_enrollment_period') }}" class="rounded-btn">Inscripciones</a></li>
						<li><a href="{{ path('admin_email_blast') }}" class="rounded-btn">Emails</a></li>
					{% endif %}
				</ul>
			{% endif %}
		</div>

		<div class="navbar-end gap-2">
			{% if app.user %}
				<span class="text-sm text-base-content/60 hidden md:block">{{ app.user.fullName ?? app.user.userIdentifier }}</span>
				<a href="{{ path('app_logout') }}" class="btn btn-sm btn-ghost text-error">Salir</a>
			{% else %}
				<a href="{{ path('app_login') }}" class="btn btn-sm btn-primary">Ingresar</a>
			{% endif %}
		</div>
	</div>

	{# Flash messages #}
	{% set flashes = app.flashes(['success','error','warning','info']) %}
	{% if flashes|length > 0 %}
		<div class="fixed top-16 right-4 z-50 flex flex-col gap-2 w-80">
			{% for type, messages in flashes %}
				{% for message in messages %}
					<div
						data-controller="flash"
						data-flash-type-value="{{ type }}"
						data-flash-message-value="{{ message }}"
						class="alert shadow-lg cursor-pointer"
						data-action="click->flash#dismiss"
					>
						{% if type == 'success' %}
							<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
						{% elseif type == 'error' %}
							<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
						{% elseif type == 'warning' %}
							<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
						{% else %}
							<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
						{% endif %}
						<span class="text-sm">{{ message }}</span>
					</div>
				{% endfor %}
			{% endfor %}
		</div>
	{% endif %}

	<main class="container mx-auto px-4 py-6">
		{% block content %}{% endblock %}
	</main>

	<footer class="footer footer-center p-4 bg-base-100 text-base-content/60 text-sm mt-8">
		<p>© {{ "now"|date("Y") }} ElectivoIA — Sistema de Inscripciones</p>
	</footer>

	{% block javascripts %}
		{{ encore_entry_script_tags('app') }}
	{% endblock %}
</body>
</html>
