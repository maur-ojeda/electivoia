{% extends 'base.html.twig' %}

{% block title %}Registro — {{ school.name }} — ElectivoIA{% endblock %}

{% block content %}
<div class="min-h-[70vh] flex items-center justify-center py-8">
	<div class="card w-full max-w-lg bg-base-100 shadow-xl">
		<div class="card-body">
			<div class="text-center mb-4">
				<h2 class="card-title text-2xl font-bold justify-center">Crear cuenta</h2>
				<p class="text-base-content/60 text-sm mt-1">{{ school.name }}</p>
			</div>

			{% if errors|length > 0 %}
				<div class="alert alert-error mb-4">
					<ul class="list-disc list-inside text-sm space-y-1">
						{% for error in errors %}
							<li>{{ error }}</li>
						{% endfor %}
					</ul>
				</div>
			{% endif %}

			<form method="post">
				<div class="form-control mb-3">
					<label class="label"><span class="label-text font-medium">Nombre completo *</span></label>
					<input type="text" name="fullName" class="input input-bordered" required
						value="{{ app.request.request.get('fullName') }}"
						placeholder="Juan Pérez González">
				</div>

				<div class="form-control mb-3">
					<label class="label">
						<span class="label-text font-medium">RUT *</span>
						<span class="label-text-alt text-base-content/50">Formato: 12345678-9</span>
					</label>
					<input type="text" name="rut" class="input input-bordered" required
						value="{{ app.request.request.get('rut') }}"
						placeholder="12345678-9">
				</div>

				<div class="form-control mb-3">
					<label class="label">
						<span class="label-text font-medium">Email</span>
						<span class="label-text-alt text-base-content/50">Opcional</span>
					</label>
					<input type="email" name="email" class="input input-bordered"
						value="{{ app.request.request.get('email') }}"
						placeholder="juan@colegio.cl">
				</div>

				<div class="form-control mb-3">
					<label class="label"><span class="label-text font-medium">Grado *</span></label>
					<select name="grade" class="select select-bordered" required>
						<option value="">Selecciona tu grado</option>
						<option value="3M" {% if app.request.request.get('grade') == '3M' %}selected{% endif %}>3° Medio</option>
						<option value="4M" {% if app.request.request.get('grade') == '4M' %}selected{% endif %}>4° Medio</option>
					</select>
				</div>

				<div class="form-control mb-3">
					<label class="label"><span class="label-text font-medium">Contraseña *</span></label>
					<input type="password" name="password" class="input input-bordered" required
						placeholder="Mínimo 6 caracteres" autocomplete="new-password">
				</div>

				<div class="form-control mb-6">
					<label class="label"><span class="label-text font-medium">Confirmar contraseña *</span></label>
					<input type="password" name="confirmPassword" class="input input-bordered" required
						placeholder="Repite tu contraseña" autocomplete="new-password">
				</div>

				<button type="submit" class="btn btn-primary w-full">Crear cuenta</button>
			</form>

			<div class="divider text-xs text-base-content/40">¿Ya tienes cuenta?</div>
			<a href="{{ path('app_login') }}" class="btn btn-ghost btn-sm w-full">Iniciar sesión</a>
		</div>
	</div>
</div>
{% endblock %}
