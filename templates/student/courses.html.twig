{% extends 'base.html.twig' %}

{% block title %}Cursos Disponibles — ElectivoIA{% endblock %}

{% block content %}
{# ─── Category image map ─── #}
{% set category_map = {
	'Filosofía': '01',
	'Matemática': '02',
	'Educación física y salud': '03',
	'Historia, geografía y ciencias sociales': '04',
	'Ciencias': '05',
	'Lengua y literatura': '07',
	'Artes': '09'
} %}

{# ─── Header ─── #}
<div class="flex items-center justify-between mb-6">
	<div>
		<h1 class="text-2xl font-bold">Cursos Disponibles</h1>
		<p class="text-base-content/60 text-sm">Hola, {{ app.user.fullName }} · {{ app.user.grade }}</p>
	</div>
	{# Chatbot button #}
	<button
		class="btn btn-primary btn-circle btn-lg shadow-lg"
		data-controller="chatbot"
		data-action="click->chatbot#toggle"
		data-chatbot-url-value="{{ path('api_chatbot') }}"
		data-chatbot-clear-url-value="{{ path('api_chatbot_clear') }}"
		title="Asistente IA"
	>
		<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
			<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
		</svg>
	</button>
</div>

{# ─── HU-16: Enrollment period banner ─── #}
{% if not enrollmentOpen %}
	<div class="alert alert-warning mb-6">
		<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
			<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-2.693-.833-3.464 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z"/>
		</svg>
		<div>
			<p class="font-semibold">El período de inscripción está cerrado.</p>
			{% if school and school.enrollmentStart and school.enrollmentStart > date() %}
				<p class="text-sm">Las inscripciones abren el {{ school.enrollmentStart|date('d/m/Y') }} a las {{ school.enrollmentStart|date('H:i') }}.</p>
			{% elseif school and school.enrollmentEnd %}
				<p class="text-sm">El plazo cerró el {{ school.enrollmentEnd|date('d/m/Y') }} a las {{ school.enrollmentEnd|date('H:i') }}.</p>
			{% endif %}
		</div>
	</div>
{% elseif school and school.enrollmentEnd %}
	<div class="alert alert-info mb-4 py-2">
		<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
			<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
		</svg>
		<span class="text-sm">Inscripciones abiertas hasta el <strong>{{ school.enrollmentEnd|date('d/m/Y') }}</strong> a las {{ school.enrollmentEnd|date('H:i') }}.</span>
	</div>
{% endif %}

{# ─── Search bar ─── #}
<form method="GET" class="mb-8">
	<div class="flex gap-3 flex-wrap items-end">
		<label class="flex items-center gap-2 cursor-pointer">
			<input type="checkbox" name="available" value="1" class="checkbox checkbox-primary checkbox-sm"
				{% if showAvailableOnly %}checked{% endif %} onchange="this.form.submit()">
			<span class="label-text text-sm">Solo con cupos</span>
		</label>
		<select name="category" class="select select-bordered w-full max-w-xs" onchange="this.form.submit()">
			<option value="">Todas las áreas</option>
			{% for cat in allCategories %}
				<option value="{{ cat.id }}" {% if cat.id == selectedCategory %}selected{% endif %}>
					{{ cat.name }}
				</option>
			{% endfor %}
		</select>
		<div class="join flex-1">
			<input
				type="text"
				name="q"
				value="{{ searchQuery }}"
				placeholder="Buscar por nombre, descripción u horario…"
				class="input input-bordered join-item flex-1"
			>
			<button type="submit" class="btn btn-primary join-item">
				<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
				</svg>
			</button>
		</div>
	</div>
</form>

{# ─── Recommended courses ─── #}
{% if recommendations|length > 0 %}
	<div class="mb-8">
		<h2 class="text-lg font-semibold mb-4 flex items-center gap-2">
			<span class="badge badge-warning badge-sm">IA</span>
			Cursos recomendados para ti
		</h2>
		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
			{% for item in recommendations %}
				{% set course = item.course %}
				{% set img = category_map[course.category.name]|default('default') %}
				<div class="card bg-base-100 shadow border-2 border-primary/30 hover:border-primary transition-colors">
					<figure class="h-36 overflow-hidden">
						<img src="{{ asset('build/images/course/' ~ img ~ '.png') }}" alt="{{ course.name }}" class="object-cover w-full h-full">
					</figure>
					<div class="card-body p-4">
						<div class="flex gap-1 flex-wrap mb-1">
							<span class="badge badge-ghost badge-xs">{{ course.category.area }}</span>
							<span class="badge badge-primary badge-xs badge-outline">{{ course.category.name }}</span>
						</div>
						<h3 class="card-title text-sm font-bold leading-tight">{{ course.name }}</h3>
						<p class="text-xs text-base-content/60 line-clamp-2">{{ course.description }}</p>
						<p class="text-xs text-base-content/70 mt-1">
							<span class="font-medium">{{ course.teacher.fullName }}</span>
							· {{ enrollmentCounts[course.id] ?? 0 }}/{{ course.maxCapacity }}
						</p>
						{% if course.schedule %}
							<p class="text-xs text-base-content/50 mt-0.5">🕐 {{ course.schedule }}</p>
						{% endif %}
						<p class="text-xs text-warning mt-1">★ {{ item.reasons|join(', ') }}</p>
						<div class="card-actions mt-3">
							{% if course.id in enrolledCourseIds %}
								<span class="badge badge-success gap-1 w-full justify-center py-3">Inscrito</span>
								<form method="post" action="{{ path('student_unenroll', {id: course.id}) }}" class="w-full">
									<button type="submit" class="btn btn-error btn-xs btn-outline w-full"
										data-controller="confirm"
										data-action="click->confirm#confirm"
										data-confirm-message-value="¿Darse de baja de {{ course.name }}?">
										Dar de baja
									</button>
								</form>
							{% else %}
								<form method="post" action="{{ path('student_enroll', {id: course.id}) }}" class="w-full">
									<button type="submit" class="btn btn-primary btn-sm w-full">Inscribirse</button>
								</form>
							{% endif %}
						</div>
					</div>
				</div>
			{% endfor %}
		</div>
	</div>
{% endif %}

{# ─── All courses ─── #}
{% set recommendedCourseIds = recommendations|map(r => r.course.id) %}
{% set otherCourses = courses|filter(c => c.id not in recommendedCourseIds) %}

{% if otherCourses|length > 0 %}
	{% if recommendations|length > 0 %}
		<h2 class="text-lg font-semibold mb-4">Todos los cursos</h2>
	{% endif %}
	<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
		{% for course in otherCourses %}
			{% set img = category_map[course.category.name]|default('default') %}
			<div class="card bg-base-100 shadow hover:shadow-md transition-shadow">
				<figure class="h-36 overflow-hidden">
					<img src="{{ asset('build/images/course/' ~ img ~ '.png') }}" alt="{{ course.name }}" class="object-cover w-full h-full">
				</figure>
				<div class="card-body p-4">
					<div class="flex gap-1 flex-wrap mb-1">
						<span class="badge badge-ghost badge-xs">{{ course.category.area }}</span>
						<span class="badge badge-outline badge-xs">{{ course.category.name }}</span>
					</div>
					<h3 class="card-title text-sm font-bold leading-tight">{{ course.name }}</h3>
					<p class="text-xs text-base-content/60 line-clamp-2">{{ course.description }}</p>
					<p class="text-xs text-base-content/70 mt-1">
						<span class="font-medium">{{ course.teacher.fullName }}</span>
						· {{ enrollmentCounts[course.id] ?? 0 }}/{{ course.maxCapacity }}
					</p>
					{% if course.schedule %}
						<p class="text-xs text-base-content/50 mt-0.5">🕐 {{ course.schedule }}</p>
					{% endif %}
					<div class="card-actions mt-3">
						{% if course.id in enrolledCourseIds %}
							<span class="badge badge-success gap-1 w-full justify-center py-3">Inscrito</span>
							<form method="post" action="{{ path('student_unenroll', {id: course.id}) }}" class="w-full">
								<button type="submit" class="btn btn-error btn-xs btn-outline w-full"
									data-controller="confirm"
									data-action="click->confirm#confirm"
									data-confirm-message-value="¿Darse de baja de {{ course.name }}?">
									Dar de baja
								</button>
							</form>
						{% else %}
							<form method="post" action="{{ path('student_enroll', {id: course.id}) }}" class="w-full">
								<button type="submit" class="btn btn-neutral btn-sm w-full">Inscribirse</button>
							</form>
						{% endif %}
					</div>
				</div>
			</div>
		{% endfor %}
	</div>
{% endif %}

{% if courses|length == 0 %}
	<div class="text-center py-16 text-base-content/50">
		<p class="text-lg">No se encontraron cursos con los filtros aplicados.</p>
		<a href="{{ path('student_courses') }}" class="btn btn-ghost btn-sm mt-4">Limpiar filtros</a>
	</div>
{% endif %}

{# ─── Chatbot widget ─── #}
<div
	data-controller="chatbot"
	data-chatbot-url-value="{{ path('api_chatbot') }}"
	data-chatbot-clear-url-value="{{ path('api_chatbot_clear') }}"
	class="fixed bottom-6 right-6 z-50"
>
	<button
		class="btn btn-primary btn-circle btn-lg shadow-lg"
		data-action="click->chatbot#toggle"
		title="Asistente IA"
	>
		<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
			<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
		</svg>
	</button>

	<div data-chatbot-target="widget" class="hidden absolute bottom-16 right-0 card bg-base-100 shadow-2xl w-80 border border-base-300">
		<div class="card-body p-0">
			<div class="flex items-center justify-between px-4 py-3 border-b bg-primary text-primary-content rounded-t-2xl">
				<span class="font-semibold text-sm">🤖 Asistente de Cursos</span>
				<div class="flex gap-1">
					<button class="btn btn-ghost btn-xs text-primary-content" data-action="click->chatbot#clearHistory" title="Limpiar chat">↺</button>
					<button class="btn btn-ghost btn-xs text-primary-content" data-action="click->chatbot#toggle">✕</button>
				</div>
			</div>
			<div
				data-chatbot-target="messages"
				class="h-60 overflow-y-auto p-3 space-y-2 bg-base-200"
			>
				<div class="chat chat-start mb-2">
					<div class="chat-bubble chat-bubble-ghost text-sm">
						¡Hola! Soy tu asistente para cursos electivos. ¿En qué puedo ayudarte? 🌟
					</div>
				</div>
			</div>
			<form data-action="submit->chatbot#send" class="flex gap-2 p-3 border-t bg-base-100 rounded-b-2xl">
				<input
					data-chatbot-target="input"
					type="text"
					placeholder="Escribe tu pregunta…"
					class="input input-bordered input-sm flex-1"
				>
				<button type="submit" class="btn btn-primary btn-sm">→</button>
			</form>
		</div>
	</div>
</div>

{# ─── Interest modal ─── #}
<dialog id="interestModal" class="modal">
	<div class="modal-box max-w-2xl">
		<h3 class="font-bold text-lg mb-2">¿Qué te gusta? 🌟</h3>
		<p class="text-sm text-base-content/60 mb-4">Indica tu nivel de interés en cada área (0 = Sin interés, 5 = Máximo).</p>

		<form method="post" action="{{ path('student_profile') }}" id="interests-form">
			{# HU-8: Preset refinement buttons #}
			<div class="mb-4">
				<p class="text-xs text-base-content/50 mb-2">Ajuste rápido:</p>
				<div class="flex gap-2 flex-wrap">
					<button type="button" class="btn btn-xs btn-outline" onclick="boostInterests(['Artes','Educación física y salud'],['Matemática','Filosofía'])">Más creativo</button>
					<button type="button" class="btn btn-xs btn-outline" onclick="boostInterests(['Ciencias','Matemática'],['Artes'])">Más científico</button>
					<button type="button" class="btn btn-xs btn-outline" onclick="boostInterests(['Historia, geografía y ciencias sociales','Lengua y literatura'],['Matemática','Ciencias'])">Más humanista</button>
					<button type="button" class="btn btn-xs btn-outline" onclick="boostInterests(['Filosofía','Lengua y literatura'],['Educación física y salud'])">Menos teórico</button>
					<button type="button" class="btn btn-xs btn-ghost text-error" onclick="resetInterests()">Limpiar todo</button>
				</div>
			</div>
			<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
				{% set categories = [
					'Filosofía',
					'Historia, geografía y ciencias sociales',
					'Lengua y literatura',
					'Matemática',
					'Ciencias',
					'Artes',
					'Educación física y salud'
				] %}
				{% for category in categories %}
					<div class="form-control bg-base-200 rounded-lg p-3">
						<label class="label py-0 mb-1">
							<span class="label-text font-medium text-sm">{{ category }}</span>
							<span class="label-text-alt" id="output-{{ loop.index }}">{{ interests[category] ?? 0 }}/5</span>
						</label>
						<input
							type="range"
							name="interests[{{ category }}]"
							min="0" max="5"
							value="{{ interests[category] ?? 0 }}"
							class="range range-primary range-xs"
							oninput="document.getElementById('output-{{ loop.index }}').textContent = this.value + '/5'"
						>
					</div>
				{% endfor %}
			</div>

			<div class="modal-action mt-6">
				<button type="submit" class="btn btn-primary">Guardar cambios</button>
				<button type="button" class="btn btn-ghost" onclick="document.getElementById('interestModal').close()">Cancelar</button>
			</div>
		</form>
	</div>
	<form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

<script>
function boostInterests(boost, reduce) {
	const form = document.getElementById('interests-form');
	boost.forEach(cat => {
		const el = form.querySelector(`input[name="interests[${cat}]"]`);
		if (el) { el.value = Math.min(5, parseInt(el.value) + 2); updateOutput(el); }
	});
	reduce.forEach(cat => {
		const el = form.querySelector(`input[name="interests[${cat}]"]`);
		if (el) { el.value = Math.max(0, parseInt(el.value) - 2); updateOutput(el); }
	});
}
function resetInterests() {
	document.getElementById('interests-form').querySelectorAll('input[type="range"]').forEach(el => {
		el.value = 0; updateOutput(el);
	});
}
function updateOutput(el) {
	const idx = el.name.match(/\d+/) ? el.name.match(/\d+/)[0] : null;
	const outputs = document.querySelectorAll('[id^="output-"]');
	outputs.forEach(o => {
		if (o.closest('.form-control')?.querySelector(`input[name="${el.name}"]`)) {
			o.textContent = el.value + '/5';
		}
	});
}
</script>

{# Link to open interests modal #}
<div class="fixed bottom-6 left-6 z-40">
	<button onclick="document.getElementById('interestModal').showModal()" class="btn btn-secondary btn-sm shadow">
		⭐ Mis intereses
	</button>
</div>

{% endblock %}
