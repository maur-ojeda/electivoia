{% extends 'base.html.twig' %}

{% block title %}Mis Cursos Inscritos — ElectivoIA{% endblock %}

{% block content %}
<div class="flex items-center justify-between mb-6">
	<h1 class="text-2xl font-bold">Mis Cursos Inscritos</h1>
	<a href="{{ path('student_attendance') }}" class="btn btn-outline btn-sm">📅 Ver asistencia</a>
</div>

{% if enrollments|length == 0 %}
	<div class="card bg-base-100 shadow text-center py-12">
		<div class="card-body">
			<p class="text-base-content/60 mb-4">No estás inscrito en ningún curso aún.</p>
			<a href="{{ path('student_courses') }}" class="btn btn-primary btn-sm">Explorar cursos disponibles</a>
		</div>
	</div>
{% else %}
	<div class="space-y-4">
		{% for enrollment in enrollments %}
			<div class="card bg-base-100 shadow border-l-4 border-success">
				<div class="card-body p-4 flex-row items-center justify-between">
					<div>
						<h3 class="font-bold text-base">{{ enrollment.course.name }}</h3>
						{% if enrollment.course.teacher %}
							<p class="text-xs text-base-content/60">Prof. {{ enrollment.course.teacher.fullName }}</p>
						{% endif %}
						<p class="text-xs text-base-content/50 mt-1">
							Inscrito el {{ enrollment.enrolledAt|date('d/m/Y H:i') }}
						</p>
					</div>
					<form method="post" action="{{ path('student_unenroll', {id: enrollment.course.id}) }}"
						data-controller="confirm"
						data-action="submit->confirm#confirm"
						data-confirm-message-value="¿Dar de baja de '{{ enrollment.course.name }}'?">
						<button type="submit" class="btn btn-error btn-xs btn-outline">Dar de baja</button>
					</form>
				</div>
			</div>
		{% endfor %}
	</div>

	<div class="mt-6">
		<a href="{{ path('student_courses') }}" class="btn btn-ghost btn-sm">← Explorar más cursos</a>
	</div>
{% endif %}
{% endblock %}
