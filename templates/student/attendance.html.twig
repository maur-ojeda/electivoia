{% extends 'base.html.twig' %}

{% block title %}Mi Asistencia — ElectivoIA{% endblock %}

{% block content %}
<div class="mb-6">
	<h1 class="text-2xl font-bold">Mi Asistencia</h1>
	<p class="text-base-content/60">Resumen de asistencia por curso inscrito.</p>
</div>

{% if attendanceData|length == 0 %}
	<div class="card bg-base-100 shadow text-center py-12">
		<div class="card-body">
			<p class="text-base-content/60 mb-4">No tienes cursos inscritos aún.</p>
			<a href="{{ path('student_courses') }}" class="btn btn-primary btn-sm">Explorar cursos disponibles</a>
		</div>
	</div>
{% else %}
	<div class="space-y-5">
		{% for item in attendanceData %}
			<div class="card bg-base-100 shadow border-l-4
				{% if item.percentage is null %}border-base-300
				{% elseif item.percentage >= 75 %}border-success
				{% elseif item.percentage >= 50 %}border-warning
				{% else %}border-error{% endif %}">
				<div class="card-body p-5">
					<div class="flex justify-between items-start">
						<div>
							<h3 class="font-bold text-base">{{ item.course.name }}</h3>
							{% if item.course.teacher %}
								<p class="text-sm text-base-content/60">Profesor: {{ item.course.teacher.fullName }}</p>
							{% endif %}
						</div>
						<div class="text-right">
							{% if item.percentage is not null %}
								<span class="text-2xl font-bold
									{{ item.percentage >= 75 ? 'text-success' : (item.percentage >= 50 ? 'text-warning' : 'text-error') }}">
									{{ item.percentage }}%
								</span>
								<p class="text-xs text-base-content/40">asistencia</p>
							{% else %}
								<span class="text-base-content/40 text-sm">Sin registros</span>
							{% endif %}
						</div>
					</div>

					{% if item.total > 0 %}
						<div class="flex gap-3 mt-3 flex-wrap">
							<span class="badge badge-success gap-1">✓ {{ item.present }} presentes</span>
							<span class="badge badge-error gap-1">✗ {{ item.absent }} ausentes</span>
							<span class="badge badge-warning gap-1">~ {{ item.justified }} justificados</span>
						</div>

						{% if item.records|length > 0 %}
							<details class="mt-4">
								<summary class="cursor-pointer text-sm text-primary hover:underline">
									Ver detalle de sesiones ({{ item.total }})
								</summary>
								<div class="mt-3 overflow-x-auto">
									<table class="table table-xs">
										<thead>
											<tr>
												<th>Fecha</th>
												<th>Estado</th>
											</tr>
										</thead>
										<tbody>
											{% for record in item.records %}
												<tr>
													<td>{{ record.date|date('d/m/Y') }}</td>
													<td>
														{% if record.status == 'present' %}
															<span class="badge badge-success badge-sm">Presente</span>
														{% elseif record.status == 'absent' %}
															<span class="badge badge-error badge-sm">Ausente</span>
														{% else %}
															<span class="badge badge-warning badge-sm">Justificado</span>
														{% endif %}
													</td>
												</tr>
											{% endfor %}
										</tbody>
									</table>
								</div>
							</details>
						{% endif %}
					{% else %}
						<p class="text-sm text-base-content/40 mt-2">El profesor aún no ha registrado sesiones para este curso.</p>
					{% endif %}
				</div>
			</div>
		{% endfor %}
	</div>

	<div class="mt-6 flex gap-4">
		<a href="{{ path('student_enrollments') }}" class="btn btn-ghost btn-sm">← Mis Cursos</a>
		<a href="{{ path('student_courses') }}" class="btn btn-ghost btn-sm">Explorar cursos</a>
	</div>
{% endif %}
{% endblock %}
