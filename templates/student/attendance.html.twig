{% extends 'student/base.html.twig' %}

{% block title %}Mi Asistencia — ElectivoIA{% endblock %}

{% block content %}
<h1 class="text-2xl font-bold mb-2">Mi Asistencia</h1>
<p class="text-gray-500 mb-6">Resumen de asistencia por curso inscrito.</p>

{% if attendanceData|length == 0 %}
    <p class="text-gray-600">No tienes cursos inscritos aún.</p>
    <a href="{{ path('student_courses') }}" class="mt-4 inline-block text-blue-600 hover:underline">Explorar cursos disponibles</a>
{% else %}
    <div class="space-y-6">
        {% for item in attendanceData %}
            <div class="bg-white rounded shadow p-5 border-l-4
                {% if item.percentage is null %}border-gray-300
                {% elseif item.percentage >= 75 %}border-green-500
                {% elseif item.percentage >= 50 %}border-yellow-400
                {% else %}border-red-500{% endif %}">

                <div class="flex justify-between items-start">
                    <div>
                        <h3 class="font-bold text-lg">{{ item.course.name }}</h3>
                        {% if item.course.teacher %}
                            <p class="text-sm text-gray-500">Profesor: {{ item.course.teacher.fullName }}</p>
                        {% endif %}
                    </div>
                    <div class="text-right">
                        {% if item.percentage is not null %}
                            <span class="text-2xl font-bold
                                {% if item.percentage >= 75 %}text-green-600
                                {% elseif item.percentage >= 50 %}text-yellow-600
                                {% else %}text-red-600{% endif %}">
                                {{ item.percentage }}%
                            </span>
                            <p class="text-xs text-gray-400">asistencia</p>
                        {% else %}
                            <span class="text-gray-400 text-sm">Sin registros</span>
                        {% endif %}
                    </div>
                </div>

                {% if item.total > 0 %}
                    <div class="flex gap-4 mt-3 text-sm">
                        <span class="bg-green-100 text-green-800 px-2 py-1 rounded">
                            ✓ Presentes: {{ item.present }}
                        </span>
                        <span class="bg-red-100 text-red-800 px-2 py-1 rounded">
                            ✗ Ausentes: {{ item.absent }}
                        </span>
                        <span class="bg-yellow-100 text-yellow-800 px-2 py-1 rounded">
                            ~ Justificados: {{ item.justified }}
                        </span>
                    </div>

                    {% if item.records|length > 0 %}
                        <details class="mt-4">
                            <summary class="cursor-pointer text-sm text-blue-600 hover:underline">
                                Ver detalle de sesiones ({{ item.total }})
                            </summary>
                            <div class="mt-2 overflow-x-auto">
                                <table class="min-w-full text-sm border">
                                    <thead class="bg-gray-50">
                                        <tr>
                                            <th class="px-3 py-2 text-left">Fecha</th>
                                            <th class="px-3 py-2 text-left">Estado</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for record in item.records %}
                                            <tr class="border-t">
                                                <td class="px-3 py-2">{{ record.date|date('d/m/Y') }}</td>
                                                <td class="px-3 py-2">
                                                    {% if record.status == 'present' %}
                                                        <span class="bg-green-100 text-green-800 px-2 py-0.5 rounded text-xs">Presente</span>
                                                    {% elseif record.status == 'absent' %}
                                                        <span class="bg-red-100 text-red-800 px-2 py-0.5 rounded text-xs">Ausente</span>
                                                    {% else %}
                                                        <span class="bg-yellow-100 text-yellow-800 px-2 py-0.5 rounded text-xs">Justificado</span>
                                                    {% endif %}
                                                </td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        </details>
                    {% endif %}
                {% else %}
                    <p class="text-sm text-gray-400 mt-2">El profesor aún no ha registrado sesiones para este curso.</p>
                {% endif %}
            </div>
        {% endfor %}
    </div>

    <div class="mt-6 flex gap-4">
        <a href="{{ path('student_enrollments') }}" class="text-blue-600 hover:underline text-sm">← Mis Cursos</a>
        <a href="{{ path('student_courses') }}" class="text-blue-600 hover:underline text-sm">Explorar cursos</a>
    </div>
{% endif %}
{% endblock %}
