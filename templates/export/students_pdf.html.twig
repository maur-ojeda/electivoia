<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <style>
        body {
            font-family: DejaVu Sans, sans-serif;
            margin: 0;
            padding: 20px;
            font-size: 10pt;
            color: #333;
        }
        .header {
            text-align: center;
            margin-bottom: 20px;
            border-bottom: 2px solid #333;
            padding-bottom: 10px;
        }
        .header h1 {
            margin: 0 0 5px 0;
            font-size: 16pt;
            color: #222;
        }
        .header h2 {
            margin: 0 0 5px 0;
            font-size: 13pt;
            color: #444;
        }
        .header p {
            margin: 2px 0;
            font-size: 9pt;
            color: #666;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 10px;
        }
        th {
            background-color: #2c3e50;
            color: #fff;
            padding: 6px 8px;
            text-align: left;
            font-size: 9pt;
            border: 1px solid #2c3e50;
        }
        td {
            padding: 5px 8px;
            border: 1px solid #ddd;
            font-size: 9pt;
        }
        tr:nth-child(even) td {
            background-color: #f9f9f9;
        }
        .empty-message {
            text-align: center;
            padding: 20px;
            color: #999;
            font-style: italic;
        }
    </style>
</head>
<body>
    <div class="header">
        {% if school %}
            <h1>{{ school.getName() }}</h1>
        {% endif %}
        <h2>{{ course.getName() }}</h2>
        {% if course.getTeacher() %}
            <p>Profesor: {{ course.getTeacher().getFullName() }}</p>
        {% endif %}
        <p>Fecha de exportación: {{ exportDate }}</p>
    </div>

    {% if data|length > 0 %}
        <table>
            <thead>
                <tr>
                    {% for column in columns %}
                        <th>{{ column.label }}</th>
                    {% endfor %}
                </tr>
            </thead>
            <tbody>
                {% for rowIndex, record in data %}
                    <tr>
                        {% for column in columns %}
                            <td>{{ column.accessor(record, rowIndex) }}</td>
                        {% endfor %}
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% else %}
        <p class="empty-message">No hay alumnos inscritos en este curso.</p>
    {% endif %}
</body>
</html>