{% extends 'base.html.twig' %}

{% block title %}Alumnos inscritos — {{ course.name }}{% endblock %}

{% block content %}
<div class="flex items-center justify-between mb-6">
	<div>
		<h1 class="text-2xl font-bold">Alumnos inscritos</h1>
		<p class="text-base-content/60 text-sm">{{ course.name }}</p>
	</div>
	<a href="{{ path('teacher_courses') }}" class="btn btn-ghost btn-sm">← Volver</a>
</div>

<div class="grid grid-cols-1 lg:grid-cols-4 gap-6">

	<div class="lg:col-span-1">
		<div class="card bg-base-100 shadow sticky top-20">
			<div class="card-body p-4">
				<h3 class="font-semibold text-sm">{{ course.name }}</h3>
				{% if course.category %}
					<p class="text-xs text-base-content/60">{{ course.category.name }}</p>
				{% endif %}
				<div class="stats stats-vertical shadow mt-3 w-full">
					<div class="stat py-2 px-3">
						<div class="stat-title text-xs">Inscritos</div>
						<div class="stat-value text-lg">{{ enrollments|length }}/{{ course.maxCapacity }}</div>
					</div>
					<div class="stat py-2 px-3">
						<div class="stat-title text-xs">Estado</div>
						<div class="stat-value text-sm {{ course.isActive ? 'text-success' : 'text-error' }}">
							{{ course.isActive ? 'Activo' : 'Inactivo' }}
						</div>
					</div>
				</div>
				<div class="space-y-2 mt-3">
					<a href="{{ path('teacher_export_students', {id: course.id}) }}" class="btn btn-outline btn-sm w-full">
						Exportar Excel
					</a>
					<a href="{{ path('teacher_report', {id: course.id}) }}" class="btn btn-primary btn-sm w-full">
						Reporte asistencia
					</a>
				</div>
			</div>
		</div>
	</div>

	<div class="lg:col-span-3">
		<div class="card bg-base-100 shadow">
			<div class="card-body p-4">
				<h4 class="font-semibold mb-4">
					Listado de alumnos
					<span class="badge badge-neutral ml-2">{{ enrollments|length }}</span>
				</h4>

				{% if enrollments|length == 0 %}
					<p class="text-base-content/60 text-sm">Aún no hay alumnos inscritos en este curso.</p>
				{% else %}
					<div class="overflow-x-auto">
						<table class="table table-sm">
							<thead>
								<tr>
									<th></th>
									<th>Nombre</th>
									<th>RUT</th>
									<th>Grado</th>
									<th>Promedio</th>
									<th>Inscrito el</th>
								</tr>
							</thead>
							<tbody>
								{% for enrollment in enrollments %}
									{% set student = enrollment.student %}
									<tr class="hover">
										<td>
											<div class="avatar">
												<div class="w-8 rounded-full">
													<img src="{{ student.avatarUrl }}" alt="{{ student.fullName }}">
												</div>
											</div>
										</td>
										<td class="font-medium">{{ student.fullName }}</td>
										<td class="text-base-content/60">{{ student.rut }}</td>
										<td>{{ student.grade }}</td>
										<td>
											{% if student.averageGrade is not null %}
												<span class="badge badge-sm
													{% if student.averageGrade >= 6.0 %}badge-success
													{% elseif student.averageGrade >= 5.0 %}badge-primary
													{% else %}badge-warning{% endif %}">
													{{ student.averageGrade|number_format(1) }}
												</span>
											{% else %}
												<span class="text-base-content/40">—</span>
											{% endif %}
										</td>
										<td class="text-xs text-base-content/60">{{ enrollment.enrolledAt|date('d/m/Y H:i') }}</td>
									</tr>
								{% endfor %}
							</tbody>
						</table>
					</div>
				{% endif %}
			</div>
		</div>
	</div>

</div>
{% endblock %}
