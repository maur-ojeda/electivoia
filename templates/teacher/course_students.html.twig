{% extends 'base.html.twig' %}

{% block title %}Alumnos inscritos — {{ course.name }}{% endblock %}

{% block content %}

<div class="rbt-page-banner-wrapper">
    <div class="rbt-banner-image"></div>
</div>

<div class="rbt-dashboard-area rbt-section-overlayping-top rbt-section-gapBottom">
    <div class="container">

        <div class="rbt-dashboard-content-wrapper">
            <div class="tutor-bg-photo bg_image height-350"
                style="background-image: url({{ asset('build/images/banner/banner-01.png') }});"></div>
            <div class="rbt-tutor-information">
                <div class="rbt-tutor-information-left">
                    <div class="thumbnail rbt-avatars size-lg">
                        <img src="{{ app.user.avatarUrl }}"/>
                    </div>
                    <div class="tutor-content">
                        <h5 class="title">Alumnos inscritos</h5>
                        <h3 class="title">{{ course.name }}</h3>
                    </div>
                </div>
            </div>
        </div>

        <div class="row mt-4">
            <div class="col-lg-3">
                <div class="rbt-default-sidebar sticky-top rbt-shadow-box rbt-gradient-border">
                    <div class="inner">
                        <div class="content-item-content">
                            <div class="rbt-default-sidebar-wrapper">
                                <div class="section-title mb--20">
                                    <h6 class="rbt-title-style-2">{{ course.name }}</h6>
                                </div>
                                <nav class="mainmenu-nav">
                                    <ul class="dashboard-mainmenu rbt-default-sidebar-list">
                                        {% if course.category %}
                                            <li>
                                                <i class="feather-tag"></i>
                                                <span>{{ course.category.name }}</span>
                                            </li>
                                        {% endif %}
                                        <li>
                                            <i class="feather-users"></i>
                                            <span>{{ enrollments|length }} / {{ course.maxCapacity }} alumnos</span>
                                        </li>
                                        <li>
                                            <i class="feather-activity"></i>
                                            <span class="{% if course.isActive %}text-success{% else %}text-danger{% endif %}">
                                                {{ course.isActive ? 'Activo' : 'Inactivo' }}
                                            </span>
                                        </li>
                                        <li class="mt-3">
                                            <a href="{{ path('teacher_export_students', {id: course.id}) }}"
                                               class="rbt-btn btn-xs bg-primary-opacity radius-round">
                                                <i class="feather-download pl--0"></i> Exportar Excel
                                            </a>
                                        </li>
                                        <li class="mt-2">
                                            <a href="{{ path('teacher_report', {id: course.id}) }}"
                                               class="rbt-btn btn-xs bg-primary-opacity radius-round">
                                                <i class="feather-bar-chart-2 pl--0"></i> Reporte asistencia
                                            </a>
                                        </li>
                                    </ul>
                                </nav>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-9">
                <div class="rbt-dashboard-content bg-color-white rbt-shadow-box mb--60">
                    <div class="content">
                        <div class="section-title mb-4">
                            <h4 class="rbt-title-style-3">
                                Listado de alumnos
                                <span class="badge bg-secondary ms-2">{{ enrollments|length }}</span>
                            </h4>
                        </div>

                        {% if enrollments|length == 0 %}
                            <p class="text-muted">Aún no hay alumnos inscritos en este curso.</p>
                        {% else %}
                            <div class="rbt-dashboard-table table-responsive">
                                <table class="rbt-table table table-borderless">
                                    <thead>
                                        <tr>
                                            <th></th>
                                            <th class="text-start">Nombre</th>
                                            <th class="text-start">RUT</th>
                                            <th class="text-start">Grado</th>
                                            <th class="text-start">Promedio</th>
                                            <th class="text-start">Inscrito el</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for enrollment in enrollments %}
                                            {% set student = enrollment.student %}
                                            <tr class="border-t">
                                                <td>
                                                    <div class="rbt-avatars m-auto size-sm">
                                                        <img src="{{ student.avatarUrl }}"/>
                                                    </div>
                                                </td>
                                                <th>{{ student.fullName }}</th>
                                                <td>{{ student.rut }}</td>
                                                <td>{{ student.grade }}</td>
                                                <td>
                                                    {% if student.averageGrade is not null %}
                                                        <span class="badge
                                                            {% if student.averageGrade >= 6.0 %}bg-success
                                                            {% elseif student.averageGrade >= 5.0 %}bg-primary
                                                            {% else %}bg-warning text-dark{% endif %}">
                                                            {{ student.averageGrade|number_format(1) }}
                                                        </span>
                                                    {% else %}
                                                        <span class="text-muted">—</span>
                                                    {% endif %}
                                                </td>
                                                <td>{{ enrollment.enrolledAt|date('d/m/Y H:i') }}</td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        {% endif %}
                    </div>
                </div>

                <a href="{{ path('teacher_courses') }}"
                   class="rbt-btn rbt-switch-btn btn-gradient btn-sm hover-transform-none">
                    ← Volver a mis cursos
                </a>
            </div>
        </div>

    </div>
</div>

{% endblock %}
