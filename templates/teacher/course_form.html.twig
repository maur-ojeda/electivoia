{% extends 'base.html.twig' %}

{% block title %}{{ formTitle }} — ElectivoIA{% endblock %}

{% block content %}
<div class="max-w-2xl mx-auto">
	<div class="mb-6">
		<h1 class="text-2xl font-bold">{{ formTitle }}</h1>
		<p class="text-base-content/60 text-sm">{{ app.user.fullName }}</p>
	</div>

	{% if errors is not empty %}
		<div class="alert alert-error mb-6">
			<ul class="list-disc list-inside text-sm">
				{% for error in errors %}
					<li>{{ error }}</li>
				{% endfor %}
			</ul>
		</div>
	{% endif %}

	<div class="card bg-base-100 shadow">
		<div class="card-body">
			<form method="post" class="space-y-5">

				<div class="form-control">
					<label class="label"><span class="label-text font-medium">Nombre del curso <span class="text-error">*</span></span></label>
					<input type="text" name="name" class="input input-bordered w-full"
						value="{{ data.name ?? '' }}" required maxlength="255"
						placeholder="Ej: Introducción a la Filosofía">
				</div>

				<div class="form-control">
					<label class="label"><span class="label-text font-medium">Descripción</span></label>
					<textarea name="description" class="textarea textarea-bordered w-full" rows="3"
						placeholder="Describe brevemente el contenido del curso…">{{ data.description ?? '' }}</textarea>
				</div>

				<div class="form-control">
					<label class="label">
						<span class="label-text font-medium">Capacidad máxima <span class="text-error">*</span></span>
					</label>
					<input type="number" name="maxCapacity" class="input input-bordered w-full"
						value="{{ data.maxCapacity ?? '' }}" required min="1" max="200"
						placeholder="Ej: 30">
					{% if course is not null and course.currentEnrollment > 0 %}
						<label class="label">
							<span class="label-text-alt text-base-content/60">Hay {{ course.currentEnrollment }} alumnos inscritos; no puede quedar menor que ese número.</span>
						</label>
					{% endif %}
				</div>

				<div class="form-control">
					<label class="label"><span class="label-text font-medium">Grados objetivo <span class="text-error">*</span></span></label>
					<div class="flex gap-6 mt-1">
						{% for grade in ['3M', '4M'] %}
							<label class="flex items-center gap-2 cursor-pointer">
								<input type="checkbox" class="checkbox checkbox-primary"
									name="targetGrades[]" value="{{ grade }}"
									{% if grade in (data.targetGrades ?? []) %}checked{% endif %}>
								<span class="label-text">{{ grade == '3M' ? 'Tercer Medio' : 'Cuarto Medio' }}</span>
							</label>
						{% endfor %}
					</div>
				</div>

				<div class="form-control">
					<label class="label"><span class="label-text font-medium">Fecha límite de inscripción</span></label>
					<input type="datetime-local" name="enrollmentDeadline" class="input input-bordered w-full"
						value="{{ data.enrollmentDeadline ?? '' }}">
					<label class="label">
						<span class="label-text-alt text-base-content/60">Opcional. Después de esta fecha no se aceptarán nuevas inscripciones.</span>
					</label>
				</div>

				<div class="form-control">
					<label class="label"><span class="label-text font-medium">Categoría</span></label>
					<select name="category" class="select select-bordered w-full">
						<option value="">Sin categoría</option>
						{% for cat in categories %}
							<option value="{{ cat.id }}" {% if (data.category ?? null) == cat.id %}selected{% endif %}>
								{{ cat.name }}
							</option>
						{% endfor %}
					</select>
				</div>

				<div class="flex gap-3 pt-4">
					<button type="submit" class="btn btn-primary">{{ submitLabel }}</button>
					<a href="{{ path('teacher_courses') }}" class="btn btn-ghost">Cancelar</a>
				</div>

			</form>
		</div>
	</div>
</div>
{% endblock %}
