{% extends 'base.html.twig' %}

{% block title %}Alumnos — {{ course.name }}{% endblock %}

{% block content %}
<div class="flex items-center justify-between mb-6">
	<div>
		<h1 class="text-2xl font-bold">Listado de Alumnos</h1>
		<p class="text-base-content/60 text-sm">{{ course.name }}</p>
	</div>
	<a href="{{ path('teacher_courses') }}" class="btn btn-ghost btn-sm">← Volver</a>
</div>

<div class="grid grid-cols-1 lg:grid-cols-4 gap-6">

	<div class="lg:col-span-1">
		<div class="card bg-base-100 shadow sticky top-20">
			<div class="card-body p-4">
				<h3 class="font-semibold text-sm">{{ course.name }}</h3>
				{% if course.category %}
					<p class="text-xs text-base-content/60">{{ course.category.area }} · {{ course.category.name }}</p>
				{% endif %}
				<div class="divider my-2"></div>
				<a href="{{ path('teacher_export_students', {id: course.id}) }}" class="btn btn-outline btn-sm w-full">
					Exportar listado
				</a>
			</div>
		</div>
	</div>

	<div class="lg:col-span-3">
		<div class="card bg-base-100 shadow">
			<div class="card-body p-4">
				<h4 class="font-semibold mb-4">Alumnos del curso</h4>
				<div class="overflow-x-auto">
					<table class="table table-sm">
						<thead>
							<tr>
								<th></th>
								<th>Alumno</th>
								<th>RUT</th>
								<th>Curso</th>
								<th>Promedio</th>
							</tr>
						</thead>
						<tbody>
							{% for student in students %}
								<tr class="hover">
									<td>
										<div class="avatar">
											<div class="w-8 rounded-full">
												<img src="{{ student.avatarUrl }}" alt="{{ student.fullName }}">
											</div>
										</div>
									</td>
									<td class="font-medium">{{ student.fullName }}</td>
									<td class="text-base-content/60">{{ student.rut }}</td>
									<td>{{ student.grade }}</td>
									<td>{{ student.averageGrade ?? '—' }}</td>
								</tr>
							{% endfor %}
						</tbody>
					</table>
				</div>
			</div>
		</div>
	</div>

</div>
{% endblock %}
