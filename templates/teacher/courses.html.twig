{% extends 'base.html.twig' %}

{% block title %}Mis Cursos — ElectivoIA{% endblock %}

{% block content %}
{% set category_map = {
	'Filosofía': '01',
	'Matemática': '02',
	'Educación física y salud': '03',
	'Historia, geografía y ciencias sociales': '04',
	'Ciencias': '05',
	'Lengua y literatura': '07',
	'Artes': '09'
} %}

<div class="flex items-center justify-between mb-6">
	<div>
		<h1 class="text-2xl font-bold">Mis Cursos</h1>
		<p class="text-base-content/60 text-sm">{{ app.user.fullName }}</p>
	</div>
	<a href="{{ path('teacher_course_new') }}" class="btn btn-primary btn-sm gap-1">
		<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
		Nuevo curso
	</a>
</div>

{# Search bar #}
<form method="GET" class="mb-6">
	<div class="flex gap-3 flex-wrap">
		<select name="category" class="select select-bordered select-sm" onchange="this.form.submit()">
			<option value="">Todas las categorías</option>
			{% for cat in allCategories %}
				<option value="{{ cat.id }}" {% if cat.id == selectedCategory %}selected{% endif %}>
					{{ cat.name }}
				</option>
			{% endfor %}
		</select>
		<div class="join flex-1">
			<input type="text" name="q" value="{{ searchQuery }}" placeholder="Buscar curso…" class="input input-bordered input-sm join-item flex-1">
			<button type="submit" class="btn btn-sm btn-neutral join-item">Buscar</button>
		</div>
	</div>
</form>

{% if courses|length == 0 %}
	<div class="text-center py-16 text-base-content/50">
		<p>No tienes cursos aún.</p>
		<a href="{{ path('teacher_course_new') }}" class="btn btn-primary btn-sm mt-4">Crear mi primer curso</a>
	</div>
{% else %}
	<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
		{% for course in courses %}
			{% set img = course.category ? category_map[course.category.name]|default('01') : '01' %}
			<div class="card bg-base-100 shadow hover:shadow-md transition-shadow {% if not course.isActive %}opacity-70{% endif %}">
				<figure class="h-36 overflow-hidden relative">
					<img src="{{ asset('build/images/course/' ~ img ~ '.png') }}" alt="{{ course.name }}" class="object-cover w-full h-full">
					{% if not course.isActive %}
						<div class="absolute inset-0 bg-black/40 flex items-center justify-center">
							<span class="badge badge-error">Inactivo</span>
						</div>
					{% endif %}
				</figure>
				<div class="card-body p-4">
					<div class="flex gap-1 flex-wrap mb-1">
						{% if course.category %}
							<span class="badge badge-ghost badge-xs">{{ course.category.area }}</span>
							<span class="badge badge-outline badge-xs">{{ course.category.name }}</span>
						{% else %}
							<span class="badge badge-ghost badge-xs">Sin categoría</span>
						{% endif %}
					</div>
					<h3 class="card-title text-sm font-bold leading-tight">{{ course.name }}</h3>
					<p class="text-xs text-base-content/60 line-clamp-2">{{ course.description|default('Sin descripción.') }}</p>
					{% if course.schedule %}
						<p class="text-xs text-base-content/60 mt-1">🕐 {{ course.schedule }}</p>
					{% endif %}
					<p class="text-xs text-base-content/70 mt-1">
						{{ enrollmentsByCourse[course.id]|length }} / {{ course.maxCapacity }} alumnos
						{% if course.enrollmentDeadline %}
							· Cierre: {{ course.enrollmentDeadline|date('d/m/Y') }}
						{% endif %}
					</p>
					<div class="card-actions mt-3 flex-col gap-2">
						<div class="flex gap-1 w-full">
							<a href="{{ path('teacher_course_students', {id: course.id}) }}" class="btn btn-xs btn-ghost flex-1">Alumnos</a>
							<a href="{{ path('teacher_report', {id: course.id}) }}" class="btn btn-xs btn-ghost flex-1">Reporte</a>
							<a href="{{ path('teacher_course_edit', {id: course.id}) }}" class="btn btn-xs btn-ghost flex-1">Editar</a>
						</div>
						<form method="post" action="{{ path('teacher_course_toggle_active', {id: course.id}) }}" class="w-full"
							data-controller="confirm"
							data-action="submit->confirm#confirm"
							data-confirm-message-value="{{ course.isActive ? 'Desactivar' : 'Activar' }} '{{ course.name }}'?">
							<button type="submit" class="btn btn-xs w-full {{ course.isActive ? 'btn-error btn-outline' : 'btn-success btn-outline' }}">
								{{ course.isActive ? 'Desactivar' : 'Activar' }}
							</button>
						</form>
					</div>
				</div>
			</div>
		{% endfor %}
	</div>
{% endif %}
{% endblock %}
