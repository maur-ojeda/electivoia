{% extends 'base.html.twig' %}

{% block title %}Mis Cursos - Profesor
{% endblock %}

{% block content %}


	<div class="rbt-page-banner-wrapper">
		<div class="rbt-banner-image"></div>
	</div>


	<!-- Start Card Style -->
	<div class="rbt-dashboard-area rbt-section-overlayping-top rbt-section-gapBottom">
		<div class="container">

			<!-- Start Dashboard Top  -->
			<div class="rbt-dashboard-content-wrapper">
				<div class="tutor-bg-photo bg_image height-350" style="background-image: url({{asset('build/images/banner/banner-01.png') }});"></div>
				<!-- Start Tutor Information  -->


				<div class="rbt-tutor-information">
					<div class="rbt-tutor-information-left">
						<div class="thumbnail rbt-avatars size-lg">
							<img src={{app.user.avatarUrl}}/>

						</div>
						<div class="tutor-content">


							<h5 class="title">Hola:
							</h5>
							<h3 class="title">{{app.user.fullName}}</h3>

						</div>
					</div>


				</div>
				<!-- End Tutor Information  -->
			</div>
			<!-- End Dashboard Top  -->

			<div class="row my-4 align-items-center">
				<div class="col-auto">
					<a href="{{ path('teacher_course_new') }}" class="rbt-btn btn-gradient btn-sm">
						<i class="feather-plus"></i> Nuevo curso
					</a>
				</div>
			</div>

			<div class="row my-2">
				<form method="GET">
					<div class="rbt-search-with-category">
						<div class="filter-select rbt-modern-select search-by-category">
							<select id="category" name="category" class="w-100">
								<option value="">Todas las categorías</option>
								{% for cat in allCategories %}
									<option value="{{ cat.id }}" {% if cat.id == selectedCategory %} selected {% endif %}>
										{{ cat.name }}
									</option>
								{% endfor %}
							</select>
						</div>
						<div class="search-field">
							<input type="text" name="q" placeholder="Buscar" value="{{ searchQuery }}">
							<button class="rbt-round-btn serach-btn" type="submit">
								<i class="feather-search"></i>
							</button>
						</div>
					</div>
				</form>
			</div>


			<div class="container">

				<div
					class="row g-5">

					<!-- Start Single Course  -->

					{% for course in courses %}


						{% set category_map = {
														'Filosofía': '01',
														'Matemática': '02',
														'Educación física y salud': '03',
														'Historia, geografía y ciencias sociales': '04',
														'Ciencias': '05',
														'Lengua y literatura': '06',
														'Artes': '07'
													} %}
						{% set image_number = course.category ? category_map[course.category.name]|default('01') : '01' %}

						<div class="col-lg-4 col-md-6 col-12">
							<div class="rbt-card variation-01 rbt-hover {% if not course.isActive %}opacity-75{% endif %}">
								<div class="rbt-card-img">
									<img src="{{ asset('build/images/course/' ~ image_number ~ '.png') }}"
										alt="{{ course.name }}">
									{% if not course.isActive %}
										<div class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center"
											style="background: rgba(0,0,0,0.35);">
											<span class="badge bg-danger fs-6">Inactivo</span>
										</div>
									{% endif %}
								</div>

								<div class="rbt-card-body">

									<div class="rbt-card-top">
										<div class="rbt-review">
											{% if course.category %}
												<span class="rbt-badge-5 me-1 bg-color-primary-opacity">{{ course.category.area }}</span>
												<span class="rbt-badge-5 bg-color-secondary-opacity">{{ course.category.name }}</span>
											{% else %}
												<span class="rbt-badge-5 bg-color-secondary-opacity">Sin categoría</span>
											{% endif %}
										</div>
									</div>

									<h5>{{ course.name }}</h5>
									<p class="small">{{ course.description|default('Sin descripción.')|slice(0, 100) }}{% if course.description|length > 100 %}…{% endif %}</p>

									<ul class="rbt-meta">
										<li class="text-muted small">
											<i class="feather-users"></i>
											{{ enrollmentsByCourse[course.id]|length }} / {{ course.maxCapacity }} alumnos
										</li>
										{% if course.enrollmentDeadline %}
											<li class="text-muted small">
												<i class="feather-clock"></i>
												Cierra: {{ course.enrollmentDeadline|date('d/m/Y H:i') }}
											</li>
										{% endif %}
									</ul>

									{# Acciones principales #}
									<div class="rbt-card-bottom d-flex flex-wrap gap-1 justify-content-end mt-2">
										<a class="rbt-btn btn-xs btn-gradient"
											href="{{ path('teacher_course_students', {id: course.id}) }}">
											<i class="feather-users"></i> Alumnos
										</a>
										<a class="rbt-btn btn-xs bg-primary-opacity"
											href="{{ path('teacher_report', {id: course.id}) }}">
											<i class="feather-bar-chart-2"></i> Reporte
										</a>
										<a class="rbt-btn btn-xs bg-primary-opacity"
											href="{{ path('teacher_course_edit', {id: course.id}) }}">
											<i class="feather-edit-2"></i> Editar
										</a>
									</div>

									{# Activar / Desactivar #}
									<div class="mt-2 text-end">
										<form method="post"
											action="{{ path('teacher_course_toggle_active', {id: course.id}) }}"
											class="d-inline"
											onsubmit="return confirm('¿Confirmas {{ course.isActive ? 'desactivar' : 'activar' }} este curso?')">
											<button type="submit"
												class="rbt-btn btn-xs {{ course.isActive ? 'btn-danger-opacity' : 'btn-success-opacity' }}">
												<i class="feather-{{ course.isActive ? 'eye-off' : 'eye' }}"></i>
												{{ course.isActive ? 'Desactivar' : 'Activar' }}
											</button>
										</form>
									</div>

								</div>
							</div>
						</div>


					{% endfor %}

					<!-- End Single Course  -->


				</div>


			</div>
		</div>
	</div>
</div>

<script>

	document.addEventListener('DOMContentLoaded', function () {
const categorySelect = document.getElementById('category');
if (categorySelect) {
categorySelect.addEventListener('change', function () {
this.closest('form').submit();
});
}
});
</script>{% endblock %}
