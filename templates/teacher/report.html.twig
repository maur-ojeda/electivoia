{% extends 'base.html.twig' %}

{% block title %}Reporte — {{ course.name }}{% endblock %}

{% block content %}
<div class="flex items-center justify-between mb-6">
	<div>
		<h1 class="text-2xl font-bold">Reporte de Asistencia</h1>
		<p class="text-base-content/60 text-sm">{{ course.name }}</p>
	</div>
	<a href="{{ path('teacher_courses') }}" class="btn btn-ghost btn-sm">← Volver</a>
</div>

<div class="grid grid-cols-1 lg:grid-cols-4 gap-6">

	{# Sidebar #}
	<div class="lg:col-span-1">
		<div class="card bg-base-100 shadow sticky top-20">
			<div class="card-body p-4">
				<h3 class="font-semibold text-sm mb-3">{{ course.name }}</h3>
				<ul class="space-y-2 text-sm text-base-content/70">
					{% if course.category %}
						<li>{{ course.category.name }}</li>
					{% endif %}
					<li>{{ reportData|length }} alumnos</li>
					<li>{{ totalSessions }} sesiones</li>
				</ul>
				<div class="divider my-3"></div>
				<div class="space-y-2">
					<a href="{{ path('teacher_report_export', {id: course.id}) }}" class="btn btn-outline btn-sm w-full">
						Exportar Excel
					</a>
					<a href="{{ path('teacher_attendance', {id: course.id}) }}" class="btn btn-primary btn-sm w-full">
						Registrar Asistencia
					</a>
				</div>
			</div>
		</div>
	</div>

	{# Main table #}
	<div class="lg:col-span-3">
		<div class="card bg-base-100 shadow">
			<div class="card-body p-4">
				<h4 class="font-semibold mb-4">Reporte por Alumno</h4>

				{% if totalSessions == 0 %}
					<p class="text-base-content/60 text-sm">Aún no hay sesiones registradas para este curso.</p>
				{% elseif reportData|length > 0 %}
					<div class="overflow-x-auto">
						<table class="table table-sm">
							<thead>
								<tr>
									<th>Alumno</th>
									<th>RUT</th>
									<th>Grado</th>
									<th class="text-center">Pres.</th>
									<th class="text-center">Aus.</th>
									<th class="text-center">Just.</th>
									<th class="text-center">%</th>
								</tr>
							</thead>
							<tbody>
								{% for item in reportData %}
									<tr class="hover">
										<td class="font-medium">{{ item.student.fullName }}</td>
										<td class="text-base-content/60">{{ item.student.rut }}</td>
										<td>{{ item.student.grade }}</td>
										<td class="text-center"><span class="badge badge-success badge-sm">{{ item.present }}</span></td>
										<td class="text-center"><span class="badge badge-error badge-sm">{{ item.absent }}</span></td>
										<td class="text-center"><span class="badge badge-warning badge-sm">{{ item.justified }}</span></td>
										<td class="text-center">
											{% if item.percentage is not null %}
												<span class="badge badge-sm
													{% if item.percentage >= 75 %}badge-success
													{% elseif item.percentage >= 50 %}badge-warning
													{% else %}badge-error{% endif %}">
													{{ item.percentage }}%
												</span>
											{% else %}
												<span class="text-base-content/40">—</span>
											{% endif %}
										</td>
									</tr>
								{% endfor %}
							</tbody>
						</table>
					</div>
					<p class="text-xs text-base-content/50 mt-3">* Ordenado de menor a mayor asistencia. Umbral mínimo recomendado: 75%.</p>
				{% endif %}
			</div>
		</div>
	</div>

</div>
{% endblock %}
